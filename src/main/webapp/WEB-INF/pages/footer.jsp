<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <title>Footer</title>
</head>

<body>
    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-about">
                <h2 class="footer-heading">AboutUs</h2>
                <p>Your one-stop destination for premium footwear. We bring the latest trends and comfort right to your
                    doorstep with quality you can trust.</p>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-tiktok"></i></a>
                </div>
            </div>

            <div class="footer-links">
                <h3 class="footer-heading">Quick Links</h3>
                <ul>
                    <li><a href="#">Men's Shoes</a></li>
                    <li><a href="#">Women's Shoes</a></li>
                    <li><a href="#">Best Sellers</a></li>
                    <li><a href="#">Special Offers</a></li>
                    <li><a href="#">New Arrivals</a></li>
                </ul>
            </div>

            <div class="footer-links">
                <h3 class="footer-heading">Customer Care</h3>
                <ul>
                    <li><a href="#">Track Order</a></li>
                    <li><a href="#">Return and Exchange</a></li>
                    <li><a href="#">Shipping Policy</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">FAQs</a></li>
                </ul>
            </div>

            <div class="footer-newsletter">
                <h3 class="footer-heading">Stay Updated</h3>
                <p style="font-size: 14px; color: #bbb; margin-bottom: 15px;">Subscribe to get notified about new
                    arrivals
                    and exclusive deals.</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Enter your email" required>
                    <button type="submit" class="newsletter-btn">SUBSCRIBE</button>
                </form>
            </div>
        </div>

        <div class="container footer-bottom">
            <div class="copyright">
                &copy; 2026 ShoesMandu. All Rights Reserved. Designed for Excellence.
            </div>
        </div>
    </footer>
</body>

</html>